# 复制为 .env 并填入你自己的值(.env 已被 .gitignore 忽略)

# === 必填 ===
WALLET=prl1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 矿机/矿池 ===
POOL=stratum+tcp://us2.alphapool.tech:5566
WORKER=rig-01
DEVICES=all
POWER_LIMIT_PCT=
STATUS_INTERVAL=30
EXTRA_ARGS=

# === 可选:中转代理(SSH 隧道,大陆机器用)===
# 设了 RELAY_HOST 就必须设 POOL_UPSTREAM。私钥二选一:挂载 RELAY_KEY_PATH 或 RELAY_KEY_B64
RELAY_HOST=
RELAY_PORT=22
POOL_UPSTREAM=us2.alphapool.tech:5566
RELAY_LOCAL_PORT=15566
RELAY_KEY_PATH=/run/secrets/relay_key
RELAY_KEY_B64=

# === 可选:上报到中控 dashboard(走中转隧道时复用同一私钥)===
REPORT=off                       # on=开启上报(需已设 RELAY_HOST)
DASHBOARD_TOKEN=prl-x7k2m9vq     # dashboard X-Token
HOST_ID=                         # dashboard 上显示的名字(留空用 WORKER)
